# Groq API key — get yours free at https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Database
# For local dev, leave blank to use SQLite
# For production (Supabase), paste your connection string:
# postgresql://user:password@host:5432/dbname
DATABASE_URL=

# App environment: "development" or "production"
APP_ENV=development

# Secret key for JWT signing — change this to a long random string in production!
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string-in-production
